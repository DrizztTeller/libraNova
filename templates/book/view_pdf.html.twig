{% extends 'base.html.twig' %}

{% block title %}Voir le PDF - {{ book.title }}{% endblock %}

{% block body %}
<style>
    body {
        background-color: #42668B !important;
        }
    #renting_history_submit:hover {
        background-color: #04294e !important;
    }
</style>


    <h1 class="text-center m-5 text-lg text-white">Voici le PDF pour {{ book.title }}</h1>
    <div id="sticky-form" class="fixed top-5 right-5 bg-white p-4 border border-gray-300 shadow-lg rounded-lg w-80 z-50">
        {{ form_start(form, {'attr': {'id': 'form_rent'}}) }}
            <div class="mb-4">
                <label for="{{ form.last_page.vars.id }}" class="block text-sm font-medium text-gray-700">Page où vous vous êtes arrêté : {{ rent.lastPage ?? 'N/A'}}</label>
                {{ form_widget(form.last_page, { 'attr': { 'class': 'mt-1 block w-full p-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500' } }) }}
            </div>

        {{ form_end(form) }}
    </div>
    
    <div id="pdf-viewer">
        <div id="pdf-canvas-container" style="display: flex; flex-direction: column; align-items: center;"></div> <!-- Un conteneur pour toutes les pages -->
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.10.377/pdf.min.js"></script>
    <script>
        var url = '{{ bookPath }}'; // chemin vers ton PDF
        var pdfjsLib = window['pdfjs-dist/build/pdf'];

        pdfjsLib.GlobalWorkerOptions.workerSrc = '//cdnjs.cloudflare.com/ajax/libs/pdf.js/2.10.377/pdf.worker.min.js';

        var loadingTask = pdfjsLib.getDocument(url);
        loadingTask.promise.then(function(pdf) {
            console.log('PDF chargé');
            
            // Parcourir toutes les pages du PDF
            for (var pageNumber = 1; pageNumber <= pdf.numPages; pageNumber++) {
                pdf.getPage(pageNumber).then(function(page) {
                    var scale = 1.5; // échelle de rendu
                    var viewport = page.getViewport({ scale: scale });

                    // Créer un élément canvas pour chaque page
                    var canvas = document.createElement('canvas');
                    document.getElementById('pdf-canvas-container').appendChild(canvas);
                    var context = canvas.getContext('2d');
                    canvas.height = viewport.height;
                    canvas.width = viewport.width;

                    var renderContext = {
                        canvasContext: context,
                        viewport: viewport
                    };
                    page.render(renderContext);
                });
            }
        });

        // Désactiver le clic droit sur toute la page
        document.addEventListener('contextmenu', function(event) {
            event.preventDefault();
        });

        // Soumettre le formulaire
        document.getElementById('renting_history_submit').addEventListener('click', function() {
            console.log("Soumission du formulaire...");
            event.preventDefault();
            document.getElementById('form_rent').submit(); 
        });

        // Désactiver la sélection de texte (prévenir la copie)
        document.getElementById('pdf-viewer').style.userSelect = 'none';
    </script>
{% endblock %}
