{% extends 'base.html.twig' %}

{% block title %}{{ book.title }} | LibraNova{% endblock %}

{% block body %}  

<div class="container mx-auto mt-5 px-4 flex flex-col gap-5">
<a href="{{ path('app_book_index') }}" class="text-blue-500 underline">
    ⬅️ Retour à la liste
</a>
    <div class="bg-white rounded-lg shadow-lg overflow-hidden">
        <div class="relative">
            {% if book.getImageUrl() %}
                <img src="{{ book.getImageUrl() }}" alt="{{ book.title }}" class="w-full h-96 object-cover">
            {% else %}
                <div class="w-full h-96 flex items-center justify-center bg-gray-200">
                    <span class="text-gray-500">Pas d'image</span>
                </div>
            {% endif %}

            <!-- Indicateur 18+ en haut à gauche -->
            {% if book.isForAdult %}
                <div class="absolute top-2 left-2 bg-red-500 text-white text-xs px-2 py-1 rounded">
                    18+
                </div>
            {% endif %}

            <!-- Formulaire de like/unlike en haut à droite -->
            <div class="absolute top-2 right-2">
                {% if not book.likes.contains(app.user) %}
                    <form class="likes" action="{{ path('app_book_like', { ref: book.getRef() }) }}" method="POST">
                        <button type="submit" class="flex items-center space-x-2 text-white rounded p-2">
                            {{ ux_icon("mdi:heart-broken", { class: "h-4 w-4 heart-broken-icon" }) }}
                        </button>
                    </form>
                {% else %}
                    <form class="likes" action="{{ path('app_book_unlike', { ref: book.getRef() }) }}" method="POST">
                        <button type="submit" class="flex items-center space-x-2 text-white rounded p-2">
                            {{ ux_icon("mdi:heart", { class: "h-4 w-4 heart-icon" }) }}
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>

        <div class="p-6">
            <h1 class="text-2xl font-bold mb-2">{{ book.title }}</h1>
            <p class="text-gray-500 mb-4">Par {{ book.author }}</p>
            <p class="text-gray-700 mb-6">{{ book.abstract|default('Aucun résumé disponible.') }}</p>

            <div class="flex items-center justify-between">
                <div class="flex gap-5 items-center">
                    <span class="text-sm text-gray-500">{{ book.releasedAt|date('d/m/Y') }}</span>
                    {% for tag in book.tags %}
                    <span class="text-sm px-2 py-1 bg-gray-200 rounded-full">{{tag.name}}</span>
                    {% endfor %}
                </div>
                {% if book.isPublished %}
                    
                {% if isRented %}
                <form action="{{ path('app_book_return', {'ref': book.getRef()}) }}" method="POST">
                    <button type="submit" 
                    class="px-6 py-2 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow-md transition duration-300">
                    📖 Rendre le livre
                </button>
            </form>
            {% else %}
            <form action="{{ path('app_book_borrow', {'ref': book.getRef()}) }}" method="POST">
                <button type="submit" 
                class="px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg shadow-md transition duration-300">
                📚 Emprunter le livre
            </button>
        </form>
        {% endif %}
        {% else %}
        <p>Livre indisponible pour le moment.</p>
        {% endif %}
                
            </div>
        </div>
    </div>
</div>
{% endblock %}


