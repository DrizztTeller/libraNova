{% extends 'base.html.twig' %}

{% block title %}Liste des Romans{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto mt-10 p-8 bg-white rounded-xl shadow-xl">
    <h1 class="text-3xl font-bold text-gray-800 mb-6 text-center">Liste des Romans Disponibles</h1>

    <ul class="space-y-4">
        {% for novel in novels %}
            <li class="p-4 bg-gray-50 rounded-lg shadow-sm hover:shadow-md transition">
                <a href="{{ path('app_novel_show', {'ref': novel.ref}) }}" class="text-lg font-semibold text-indigo-600 hover:text-indigo-800">
                    {{ novel.title }}
                </a>
                <div class="text-sm text-gray-600">Auteur : <span class="font-medium">{{ novel.author }}</span></div>
                <div class="text-gray-500 text-sm">Date de publication : {{ novel.releasedAt ? novel.releasedAt|date('d/m/Y') : 'Non spécifiée' }}</div>
            </li>
        {% else %}
            <li class="text-center text-gray-500">Aucun roman trouvé.</li>
        {% endfor %}
    </ul>
</div>
{% endblock %}