{% extends 'base.html.twig' %}

{% block title %}User{% endblock %}

{% block body %}
    <h1>User</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ user.id }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ user.email }}</td>
            </tr>
            <tr>
                <th>Roles</th>
                <td>{{ user.roles ? user.roles|json_encode : '' }}</td>
            </tr>
            <tr>
                <th>Password</th>
                <td>{{ user.password }}</td>
            </tr>
            <tr>
                <th>Username</th>
                <td>{{ user.username }}</td>
            </tr>
            <tr>
                <th>Rented_books_count</th>
                <td>{{ user.rentedBooksCount }}</td>
            </tr>
            <tr>
                <th>Is_adult</th>
                <td>{{ user.isAdult ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Ref</th>
                <td>{{ user.ref }}</td>
            </tr>
            <tr>
                <th>IsVerified</th>
                <td>{{ user.isVerified ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Is_terms</th>
                <td>{{ user.isTerms ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Is_gpdr</th>
                <td>{{ user.isGpdr ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    {{ include('user/_delete_form.html.twig') }}
{% endblock %}
