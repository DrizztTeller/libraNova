{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
<div class="container mx-auto mt-10 p-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Sidebar -->
        <div class="bg-gray-100 p-4 rounded-lg shadow-md">
            <h2 class="text-lg font-semibold text-gray-700 mb-4">Mon Profil</h2>
            
            <!-- User Info -->
            <div class="mb-6">
                <p class="text-gray-800"><strong>Nom d'utilisateur :</strong> {{ app.user.username }}</p>
                <p class="text-gray-800"><strong>Email :</strong> {{ app.user.email }}</p>
            </div>

            <!-- Dashboard Menu -->
            <nav class="mb-6">
                <ul class="space-y-2">
                    <li><a href="{{ path('app_user_bookmarked') }}" class="block px-4 py-2 bg-gray-200 rounded-md hover:bg-gray-300">Mes Favoris</a></li>
                    <li><a href="{{ path('app_user_rented') }}" class="block px-4 py-2 bg-gray-200 rounded-md hover:bg-gray-300">Mes Emprunts</a></li>
                    <li><a href="{{ path('app_user_renting_history') }}" class="block px-4 py-2 bg-gray-200 rounded-md hover:bg-gray-300">Mon Historique d'emprunts</a></li>
                    <li><a href="{{ path('app_user_login_history') }}" class="block px-4 py-2 bg-gray-200 rounded-md hover:bg-gray-300">Mon Historique de connexion</a></li>
                </ul>
            </nav>

            <!-- Delete Account Button -->
            {{ include('user/_delete_form.html.twig') }}
        </div>

        <!-- Profile Form -->
        <div class="md:col-span-2 bg-white p-6 rounded-lg shadow-md">
            <h2 class="text-xl font-semibold text-gray-700 mb-4">Modifier mon profil</h2>

            {{ form_start(userForm) }}
                <div class="space-y-4">
                    {{ form_row(userForm.username) }}
                    {{ form_row(userForm.email) }}
                    {{ form_row(userForm.password) }}
                    {{ form_row(userForm.plainPassword) }}
                </div>
            {{ form_end(userForm) }}
        </div>
    </div>
</div>
{% endblock %}

    
