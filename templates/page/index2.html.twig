{% extends 'base.html.twig' %}

{% block title %}Bienvenue sur LibraNova - Votre bibliothèque numérique{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <section class="relative py-32 bg-cover bg-center" style="background-image: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('https://expodif.fr/wp-content/uploads/2024/10/stack-books-with-library-scene-1024x512.jpg')">
        <div class="container mx-auto px-4 text-center text-white">
            <h1 class="text-5xl font-bold mb-6">Bienvenue sur LibraNova</h1>
            <p class="text-xl mb-10 max-w-3xl mx-auto">Découvrez un monde de littérature, partagez vos passions et explorez de nouveaux horizons.</p>
            <div class="flex justify-center space-x-4">
                    <a href="{{ path('app_register') }}" class="px-6 py-3 bg-transparent border-2 border-white text-white hover:bg-white hover:text-blue-800 rounded-lg transition duration-300">Rejoindre la communauté</a>
            </div>
        </div>
    </section>
    <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-center mb-6">Bibliothèque de Romans</h1>

    <!-- Formulaire de recherche -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-10">
        <h2 class="text-xl font-semibold mb-4">Rechercher un roman</h2>
        
        {{ form_start(form) }}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.title, 'Titre', {'label_attr': {'class': 'block mb-1 font-medium'}}) }}
                    {{ form_widget(form.title) }}
                </div>
                
                <div>
                    {{ form_label(form.author, 'Auteur', {'label_attr': {'class': 'block mb-1 font-medium'}}) }}
                    {{ form_widget(form.author) }}
                </div>
                
                <div>
                    {{ form_label(form.tags, 'Tags', {'label_attr': {'class': 'block mb-1 font-medium'}}) }}
                    {{ form_widget(form.tags) }}
                </div>
                
                <div>
                    {{ form_label(form.orderBy, 'Trier par', {'label_attr': {'class': 'block mb-1 font-medium'}}) }}
                    {{ form_widget(form.orderBy) }}
                </div>
                
                <div class="md:col-span-2">
                    {{ form_label(form.orderDirection, 'Direction', {'label_attr': {'class': 'block mb-1 font-medium'}}) }}
                    <div class="flex space-x-4">
                        {{ form_widget(form.orderDirection) }}
                    </div>
                </div>
            </div>
            
            <div class="mt-4 text-center">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-md transition duration-200">
                    Rechercher
                </button>
            </div>
        {{ form_end(form) }}
    </div>

    <!-- Affichage des résultats de recherche si présents -->
    {% if isSearchResults %}
        <section class="mb-16">
            <h2 class="text-2xl font-semibold mb-4">Résultats de recherche</h2>
            
            {% if searchResults|length > 0 %}
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                    {% for novel in searchResults %}
                        <div class="bg-white rounded-lg shadow-md overflow-hidden flex flex-col h-full">
                            <div class="h-48 bg-gray-300 relative">
                                {% if novel.pic %}
                                    <img src="{{ novel.pic }}" alt="{{ novel.title }}" class="w-full h-full object-cover">
                                {% else %}
                                    <div class="w-full h-full flex items-center justify-center bg-gray-200">
                                        <span class="text-gray-500">Pas d'image</span>
                                    </div>
                                {% endif %}
                                {% if novel.isForAdult %}
                                    <div class="absolute top-2 right-2 bg-red-500 text-white text-xs px-2 py-1 rounded">18+</div>
                                {% endif %}
                            </div>
                            <div class="p-4 flex-grow flex flex-col">
                                <h3 class="font-semibold text-lg mb-1">{{ novel.title }}</h3>
                                <p class="text-sm text-gray-500 mb-2">Par {{ novel.author }}</p>
                                <p class="text-sm text-gray-600 mb-3 line-clamp-3">{{ novel.abstract|default('Aucun résumé disponible.') }}</p>
                                <div class="mt-auto pt-3 border-t">
                                    <a href="{{ path('app_novel_show', {'ref': novel.ref}) }}" class="inline-block bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-1.5 px-3 rounded transition duration-200">
                                        Voir le détail
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="bg-yellow-50 border border-yellow-200 text-yellow-800 p-4 rounded-md">
                    Aucun roman ne correspond à votre recherche.
                </div>
            {% endif %}
        </section>
    {% else %}
        <!-- Sections existantes (Romans Récemment Publiés, etc.) -->
    <!-- Featured Novels Section -->
    <section class="container mx-auto px-4 py-16">
        <h2 class="text-3xl font-bold mb-8 relative pb-3 after:content-[''] after:absolute after:bottom-0 after:left-0 after:h-1 after:w-20 after:bg-blue-600">Romans à découvrir</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for novel in novelsLatest %}
                <div class="transform transition duration-300 hover:-translate-y-2">
                    <div class="bg-white rounded-lg overflow-hidden shadow-md h-full">
                        <img src="{{ novel.pic }}" alt="{{ novel.title }}" class="w-full h-56 object-cover">
                        <div class="p-6">
                            <h5 class="font-bold text-xl mb-2">{{ novel.title }}</h5>
                            <p class="text-gray-600 mb-2">{{ novel.author }}</p>
                            <p class="text-gray-800 mb-4">{{ novel.abstract|striptags|slice(0, 100) }}...</p>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        <div class="text-center mt-10">
          
        </div>
    </section>

    <!-- Statistics Section -->
    {# <section class="bg-gray-100 py-16">
        <div class="container mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="text-center">
                    <div class="text-4xl font-bold text-blue-600 mb-2">{{ novelCount }}</div>
                    <div class="text-xl text-gray-700">Romans publiés</div>
                </div>
                <div class="text-center">
                    <div class="text-4xl font-bold text-blue-600 mb-2">{{ userCount }}</div>
                    <div class="text-xl text-gray-700">Membres actifs</div>
                </div>
                <div class="text-center">
                    <div class="text-4xl font-bold text-blue-600 mb-2">{{ reviewCount }}</div>
                    <div class="text-xl text-gray-700">Avis partagés</div>
                </div>
            </div>
        </div>
    </section> #}

    <!-- Categories Section -->
    {# <section class="container mx-auto px-4 py-16">
        <h2 class="text-3xl font-bold mb-8 relative pb-3 after:content-[''] after:absolute after:bottom-0 after:left-0 after:h-1 after:w-20 after:bg-blue-600">Explorez les catégories</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {% for category in categories %}
                <div class="bg-white rounded-lg shadow p-6 text-center hover:shadow-lg transition duration-300">
