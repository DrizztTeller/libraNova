{% extends 'base.html.twig' %}

{% block title %}Bienvenue sur LibraNova - Votre bibliothèque numérique{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <section class="relative py-32 bg-cover bg-center" style="background-image: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('https://expodif.fr/wp-content/uploads/2024/10/stack-books-with-library-scene-1024x512.jpg')">
        <div class="container mx-auto px-4 text-center text-white">
            <h1 class="text-5xl font-bold mb-6">Bienvenue sur LibraNova</h1>
            <p class="text-xl mb-10 max-w-3xl mx-auto">Découvrez un monde de littérature, partagez vos passions et explorez de nouveaux horizons.</p>
            <div class="flex justify-center space-x-4">
                    <a href="{{ path('app_register') }}" class="px-6 py-3 bg-transparent border-2 border-white text-white hover:bg-white hover:text-blue-800 rounded-lg transition duration-300">Rejoindre la communauté</a>
            </div>
        </div>
    </section>
    
    <!-- Featured Novels Section -->
    <section class="container mx-auto px-4 py-16">
        <h2 class="text-3xl font-bold mb-8 relative pb-3 after:content-[''] after:absolute after:bottom-0 after:left-0 after:h-1 after:w-20 after:bg-blue-600">Romans à découvrir</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for novel in novelsLatest %}
                <div class="transform transition duration-300 hover:-translate-y-2">
                    <div class="bg-white rounded-lg overflow-hidden shadow-md h-full">
                        <img src="{{ novel.getImageUrl}}" 
                            alt="{{ novel.title }}" 
                            class="w-full h-56 object-cover">
                        <div class="p-6">
                            <h5 class="font-bold text-xl mb-2">{{ novel.title }}</h5>
                            <p class="text-gray-600 mb-2">{{ novel.author }}</p>
                            <p class="text-gray-800 mb-4">{{ novel.abstract|striptags|slice(0, 100) }}...</p>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        <div class="text-center mt-10">
          
        </div>
    </section>

    <!-- Statistics Section -->
    {# <section class="bg-gray-100 py-16">
        <div class="container mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="text-center">
                    <div class="text-4xl font-bold text-blue-600 mb-2">{{ novelCount }}</div>
                    <div class="text-xl text-gray-700">Romans publiés</div>
                </div>
                <div class="text-center">
                    <div class="text-4xl font-bold text-blue-600 mb-2">{{ userCount }}</div>
                    <div class="text-xl text-gray-700">Membres actifs</div>
                </div>
                <div class="text-center">
                    <div class="text-4xl font-bold text-blue-600 mb-2">{{ reviewCount }}</div>
                    <div class="text-xl text-gray-700">Avis partagés</div>
                </div>
            </div>
        </div>
    </section> #}

    <!-- Categories Section -->
    {# <section class="container mx-auto px-4 py-16">
        <h2 class="text-3xl font-bold mb-8 relative pb-3 after:content-[''] after:absolute after:bottom-0 after:left-0 after:h-1 after:w-20 after:bg-blue-600">Explorez les catégories</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {% for category in categories %}
                <div class="bg-white rounded-lg shadow p-6 text-center hover:shadow-lg transition duration-300">
                    <h5 class="font-bold text-xl mb-2">{{ category.title }}</h5>
                    <p class="text-gray-600 mb-4">{{ category.novels|length }} romans</p>
                    <a href="{{ path('category_show', {'id': category.id}) }}" class="inline-block px-4 py-2 border border-gray-400 text-gray-700 rounded hover:bg-gray-200 transition-colors duration-300">Explorer</a>
                </div>
            {% endfor %}
        </div>
    </section> #}

    <!-- Latest Reviews Section -->
    {# <section class="container mx-auto px-4 py-16">
        <h2 class="text-3xl font-bold mb-8 relative pb-3 after:content-[''] after:absolute after:bottom-0 after:left-0 after:h-1 after:w-20 after:bg-blue-600">Derniers avis</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {% for review in latestReviews %}
                <div class="bg-white rounded-lg shadow p-6">
                    <div class="flex justify-between items-center mb-4">
                        <h5 class="font-bold text-lg">{{ review.novel.title }}</h5>
                        <div class="flex">
                            {% for i in 1..5 %}
                                {% if i <= review.rating %}
                                    <svg class="w-5 h-5 text-yellow-500 fill-current" viewBox="0 0 24 24">
                                        <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"></path>
                                    </svg>
                                {% else %}
                                    <svg class="w-5 h-5 text-gray-300 fill-current" viewBox="0 0 24 24">
                                        <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"></path>
                                    </svg>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    <p class="text-gray-800 mb-4">{{ review.content|striptags|slice(0, 150) }}...</p>
                    <div class="flex justify-between items-center text-sm text-gray-600">
                        <span>Par {{ review.user.usertitle }}</span>
                        <span>{{ review.createdAt|date('d/m/Y') }}</span>
                    </div>
                </div>
            {% endfor %}
        </div>
    </section> #}

    <!-- CTA Section -->
    <section class="bg-blue-600 text-white py-16">
        <div class="container mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold mb-4">Prêt à commencer votre voyage littéraire?</h2>
            <p class="text-xl mb-8 max-w-3xl mx-auto">Rejoignez notre communauté de passionnés de littérature dès aujourd'hui.</p>
            {% if app.user %}
            {% else %}
                <div class="flex justify-center space-x-4">
                    <a href="{{ path('app_register') }}" class="px-6 py-3 bg-white text-blue-600 rounded-lg hover:bg-gray-100 transition duration-300">S'inscrire</a>
                    <a href="{{ path('app_login') }}" class="px-6 py-3 bg-transparent border-2 border-white text-white hover:bg-white hover:text-blue-600 rounded-lg transition duration-300">Se connecter</a>
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
                    