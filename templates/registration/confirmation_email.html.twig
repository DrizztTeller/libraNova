<div class="font-sans max-w-lg mx-auto p-6 bg-white shadow-md rounded-lg">
    <h1 class="text-2xl font-bold text-gray-800">📧 Please confirm your email!</h1>

    <p class="text-gray-600 mt-2">
        Please confirm your email address by clicking the button below:
    </p>

    <div class="mt-4">
        <a href="{{ signedUrl|raw }}" class="bg-blue-500 text-white font-medium px-6 py-2 rounded-lg shadow-md hover:bg-blue-600 transition">
            Confirm my Email
        </a>
    </div>

    <p class="text-gray-500 mt-4 text-sm">
        ⚠️ This link will expire in 
        <strong>{{ expiresAtMessageKey|trans(expiresAtMessageData, 'messages') }}</strong>.
    </p>

    <p class="text-gray-400 text-xs mt-2">
        If you didn't request this email, please ignore it.
    </p>
</div>
