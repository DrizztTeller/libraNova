<div style="font-family: Arial, Helvetica, sans-serif; max-width: 600px; margin: auto; padding: 20px;">
    <h1 style="color: #333;">📧 Please confirm your email!</h1>

    <p style="font-size: 16px; color: #555;">
        Please confirm your email address by clicking the button below:
    </p>

    <p style="margin: 20px 0;">
        <a href="{{ signedUrl|raw }}" style="background-color: #4CAF50; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px;">Confirm my Email</a>
    </p>

    <p style="color: #555;">
        ⚠️ This link will expire in <strong>{{ expiresAtMessageKey|trans(expiresAtMessageData, 'messages') }}</strong>.
    </p>

    <p style="color: #777; font-size: 14px;">If you didn't request this email, please ignore it.</p>
</div>
