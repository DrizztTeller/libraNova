{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
<div class="max-w-lg mx-auto mt-10 p-8 bg-white rounded-xl shadow-xl">
    <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">Créer un compte</h1>

    {{ form(registrationForm, {'attr': {'class': 'form space-y-4'}}) }} 

    <p class="mt-4 text-center text-gray-600 text-sm">
        Vous avez déjà un compte ?
        <a href="{{ path('app_login') }}" class="text-indigo-600 hover:underline">Connectez-vous ici</a>
    </p>

</div>
{% endblock %}
