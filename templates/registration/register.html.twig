{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-screen bg-gray-100">
    <div class="w-full max-w-md bg-white shadow-lg rounded-lg p-6">

        {# Affichage des erreurs de vérification d'email #}
        {% for flash_error in app.flashes('verify_email_error') %}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4" role="alert">
                {{ flash_error }}
            </div>
        {% endfor %}

        <h2 class="text-2xl font-semibold text-center text-gray-800 mb-4">Créer un compte</h2>

        {# Affichage des erreurs globaux du formulaire #}
        {% if registrationForm.vars.errors|length > 0 %}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                {{ form_errors(registrationForm) }}
            </div>
        {% endif %}

        {{ form_start(registrationForm, {'attr': {'class': 'space-y-4'}}) }}

            <div>
                {{ form_label(registrationForm.email, 'Adresse Email', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(registrationForm.email, {'attr': {'class': 'mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500'}}) }}
            </div>

            <div>
                {{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500'}}) }}
            </div>

            <div class="flex items-center">
                {{ form_widget(registrationForm.isMajor, {'attr': {'class': 'h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500'}}) }}
                <label for="{{ registrationForm.isMajor.vars.id }}" class="ml-2 block text-sm text-gray-900">
                    Vous confirmez que vous êtes majeur
                </label>
            </div>

            <div class="flex items-center">
                {{ form_widget(registrationForm.isTerms, {'attr': {'class': 'h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500'}}) }}
                <label for="{{ registrationForm.isTerms.vars.id }}" class="ml-2 block text-sm text-gray-900">
                    J'accepte les CGU et CGV
                </label>
            </div>

            <div class="flex items-center">
                {{ form_widget(registrationForm.isGpdr, {'attr': {'class': 'h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500'}}) }}
                <label for="{{ registrationForm.isGpdr.vars.id }}" class="ml-2 block text-sm text-gray-900">
                    J'accepte la politique RGPD de miniamaker
                </label>
            </div>

            <div class="flex items-center">
                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500'}}) }}
                <label for="{{ registrationForm.agreeTerms.vars.id }}" class="ml-2 block text-sm text-gray-900">
                    J'accepte les termes et conditions
                </label>
            </div>

            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded-md shadow-md transition">
                S'inscrire
            </button>

        {{ form_end(registrationForm) }}

        <p class="mt-4 text-center text-sm text-gray-600">
            Déjà un compte ? 
            <a href="{{ path('app_login') }}" class="text-indigo-600 hover:text-indigo-800 font-medium">Se connecter</a>
        </p>
    </div>
</div>
{% endblock %}
